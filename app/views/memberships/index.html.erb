<% content_for :title, "#{t('memberships.title')} — #{current_venue.name}" %>
<%= render "shared/page_header", title: t("memberships.title"), subtitle: t("memberships.subtitle") %>
<section class="mx-auto max-w-6xl px-5 py-10">
  <div class="grid gap-5 md:grid-cols-3">
    <% @plans.each do |plan| %>
      <div class="card relative flex flex-col p-7 <%= 'ring-2 ring-[color:var(--color-accent)]' if plan.popular %>">
        <% if plan.popular %><span class="chip absolute -top-3 left-1/2 -translate-x-1/2 bg-[color:var(--color-accent)] text-white"><%= t("memberships.popular") %></span><% end %>
        <h3 class="font-display text-2xl font-bold"><%= plan.name %></h3>
        <div class="mt-3 flex items-baseline gap-1">
          <span class="font-display text-4xl font-black gradient-text"><%= plan.price.format %></span>
          <span class="text-sm text-[color:var(--color-faint)]"><%= t("memberships.period.#{plan.period}") %></span>
        </div>
        <p class="mt-3 text-sm text-[color:var(--color-muted)]"><%= plan.description %></p>
        <ul class="mt-5 flex-1 space-y-2 text-sm">
          <% plan.benefit_list.each do |b| %>
            <li class="flex items-center gap-2"><span class="text-[color:var(--color-electric)]">✓</span> <%= b %></li>
          <% end %>
        </ul>
        <% if user_signed_in? %>
          <%= button_to t("memberships.choose"), account_subscriptions_path(membership_plan_id: plan.id), class: "btn #{plan.popular ? 'btn-primary' : 'btn-ghost'} mt-6 w-full" %>
        <% else %>
          <%= link_to t("memberships.choose"), new_user_session_path, class: "btn #{plan.popular ? 'btn-primary' : 'btn-ghost'} mt-6 w-full" %>
        <% end %>
      </div>
    <% end %>
  </div>
</section>
