<div class="flex items-center justify-between">
  <h1 class="font-display text-3xl font-black"><%= t("account.my_bookings") %></h1>
  <%= link_to t("account.new_booking"), new_account_booking_path, class: "btn btn-primary !px-4 !py-2 text-sm" %>
</div>
<div class="mt-6 space-y-3">
  <% @bookings.each do |b| %>
    <%= link_to account_booking_path(b), class: "card flex items-center justify-between p-4 hover:border-white/20" do %>
      <div>
        <div class="font-medium"><%= b.session_price&.name || t("nav.book") %> · <%= b.reference %></div>
        <div class="text-xs text-[color:var(--color-faint)]"><%= l(b.starts_at, format: :long) if b.starts_at %></div>
      </div>
      <div class="flex items-center gap-3">
        <span class="font-display gradient-text"><%= b.total&.format %></span>
        <span class="chip"><%= b.status %></span>
      </div>
    <% end %>
  <% end %>
  <% if @bookings.empty? %><p class="text-[color:var(--color-muted)]"><%= t("account.none") %></p><% end %>
</div>
