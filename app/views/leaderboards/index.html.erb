<% content_for :title, "#{t('drivers.title')} — #{current_venue.name}" %>
<section class="mx-auto max-w-4xl px-5 py-10">
  <h1 class="font-display text-4xl font-black"><%= t("drivers.title") %></h1>
  <p class="mt-2 text-[color:var(--color-muted)]"><%= t("drivers.subtitle") %></p>

  <div class="card mt-8 overflow-hidden">
    <% @drivers.each_with_index do |driver, i| %>
      <%= link_to driver_path(driver), class: "flex items-center gap-4 border-b border-[color:var(--color-line)]/50 px-4 py-3.5 transition hover:bg-white/[0.03]" do %>
        <span class="grid h-9 w-9 place-items-center rounded-xl font-display text-sm <%= i.zero? ? 'bg-[color:var(--color-amber)] text-black' : (i < 3 ? 'bg-white/10' : 'bg-white/5 text-[color:var(--color-muted)]') %>"><%= i + 1 %></span>
        <div class="min-w-0 flex-1">
          <div class="truncate font-semibold"><%= driver.display_name %></div>
          <div class="text-xs text-[color:var(--color-faint)]"><%= driver.country %></div>
        </div>
        <div class="text-end">
          <div class="font-mono text-sm text-[color:var(--color-electric)]"><%= driver.best_lap_label %></div>
          <div class="text-xs text-[color:var(--color-faint)]"><%= driver.points || 0 %> <%= t("drivers.points") %></div>
        </div>
      <% end %>
    <% end %>
    <% if @drivers.empty? %><p class="px-4 py-12 text-center text-[color:var(--color-faint)]"><%= t("account.none") %></p><% end %>
  </div>
</section>
