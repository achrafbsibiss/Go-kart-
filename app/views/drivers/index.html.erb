<% content_for :title, "#{t('drivers.title')} — #{current_venue.name}" %>
<section class="mx-auto max-w-5xl px-5 py-10">
  <h1 class="font-display text-4xl font-black"><%= t("drivers.title") %></h1>
  <p class="mt-2 text-[color:var(--color-muted)]"><%= t("drivers.subtitle") %></p>
  <div class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    <% @drivers.each do |driver| %>
      <%= link_to driver_path(driver), class: "card flex items-center gap-4 p-4 hover:border-white/20" do %>
        <span class="grid h-12 w-12 place-items-center overflow-hidden rounded-2xl bg-white/5">
          <% if driver.avatar.attached? %><%= image_tag driver.avatar, class: "h-full w-full object-cover" %><% else %><%= icon(:user, css: "h-6 w-6 text-[color:var(--color-faint)]") %><% end %>
        </span>
        <div class="min-w-0">
          <div class="truncate font-display font-bold"><%= driver.display_name %></div>
          <div class="text-xs text-[color:var(--color-faint)]"><%= driver.total_races || 0 %> <%= t("drivers.races") %> · <%= driver.best_lap_label %></div>
        </div>
      <% end %>
    <% end %>
  </div>
</section>
