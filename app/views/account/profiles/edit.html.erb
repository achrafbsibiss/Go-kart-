<h1 class="font-display text-3xl font-black"><%= t("account.profile") %></h1>
<%= form_with model: current_user, url: account_profile_path, method: :patch, class: "card mt-6 space-y-4 p-7" do |f| %>
  <div class="grid gap-4 sm:grid-cols-2">
    <div><label class="text-sm text-[color:var(--color-muted)]">First name</label><%= f.text_field :first_name, class: "mt-1 w-full rounded-xl border border-[color:var(--color-line)] bg-[color:var(--color-surface-2)] px-4 py-3" %></div>
    <div><label class="text-sm text-[color:var(--color-muted)]">Last name</label><%= f.text_field :last_name, class: "mt-1 w-full rounded-xl border border-[color:var(--color-line)] bg-[color:var(--color-surface-2)] px-4 py-3" %></div>
  </div>
  <div><label class="text-sm text-[color:var(--color-muted)]">Phone</label><%= f.telephone_field :phone, class: "mt-1 w-full rounded-xl border border-[color:var(--color-line)] bg-[color:var(--color-surface-2)] px-4 py-3" %></div>
  <div><label class="text-sm text-[color:var(--color-muted)]">Locale</label><%= f.select :locale, User::LOCALES.map { |l| [t("locales.#{l}"), l] }, {}, class: "mt-1 w-full rounded-xl border border-[color:var(--color-line)] bg-[color:var(--color-surface-2)] px-4 py-3" %></div>
  <label class="flex items-center gap-2 text-sm"><%= f.check_box :marketing_opt_in, class: "accent-[color:var(--color-accent)]" %> Marketing emails</label>
  <div class="flex gap-3">
    <%= f.submit t("actions.save"), class: "btn btn-primary cursor-pointer" %>
    <%= link_to t("actions.cancel"), account_profile_path, class: "btn btn-ghost" %>
  </div>
<% end %>
