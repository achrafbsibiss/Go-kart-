<% content_for :title, "#{t('nav.sign_in')} — #{current_venue.name}" %>

<section class="mx-auto grid min-h-[calc(100dvh-4rem)] max-w-7xl lg:grid-cols-2">
  <%# ── Left: image panel (desktop) ── %>
  <div class="relative hidden overflow-hidden border-e border-[color:var(--color-line)] lg:block">
    <%= image_tag "hero.jpg", alt: "", class: "absolute inset-0 h-full w-full object-cover" %>
    <div class="absolute inset-0" style="background:linear-gradient(120deg, var(--color-night) 8%, transparent 70%), linear-gradient(0deg, var(--color-night) 4%, transparent 45%)"></div>
    <div class="hazard hazard-red absolute inset-x-0 top-0"></div>

    <div class="relative flex h-full flex-col justify-between p-10">
      <span class="chip w-fit"><span class="live-dot"></span> <%= current_venue.city %> · <%= current_venue.country %></span>
      <div>
        <p class="font-mono2 text-xs uppercase tracking-[0.3em] text-[color:var(--color-electric)]"><%= t("home.hero_eyebrow") %></p>
        <h2 class="skew-speed mt-3 text-6xl text-[color:var(--color-ink)]"><%= current_venue.name %></h2>
        <p class="mt-4 max-w-sm text-sm text-[color:var(--color-muted)]"><%= t("meta.description") %></p>
      </div>
    </div>
  </div>

  <%# ── Right: form ── %>
  <div class="flex items-center justify-center px-5 py-12 sm:px-10">
    <div class="w-full max-w-sm animate-rise">
      <span class="font-mono2 text-xs uppercase tracking-[0.3em] text-[color:var(--color-muted)]">// <%= t("account.dashboard") %></span>
      <h1 class="mt-2 text-5xl"><%= t("nav.sign_in") %></h1>
      <div class="hazard mt-4 w-24"></div>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "mt-8 space-y-5" }) do |f| %>
        <div>
          <%= f.label :email, t("contact.email"), class: "font-mono2 text-[11px] uppercase tracking-widest text-[color:var(--color-muted)]" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "you@example.com",
                class: "mt-1.5 w-full rounded-[var(--radius-xl2)] border border-[color:var(--color-line)] bg-[color:var(--color-surface-2)] px-4 py-3 text-[color:var(--color-ink)] outline-none transition focus:border-[color:var(--color-electric)]" %>
        </div>

        <div>
          <div class="flex items-center justify-between">
            <%= f.label :password, "Password", class: "font-mono2 text-[11px] uppercase tracking-widest text-[color:var(--color-muted)]" %>
            <% if devise_mapping.recoverable? %>
              <%= link_to "Forgot?", new_password_path(resource_name), class: "font-mono2 text-[11px] uppercase tracking-widest text-[color:var(--color-electric)] hover:underline" %>
            <% end %>
          </div>
          <%= f.password_field :password, autocomplete: "current-password", placeholder: "••••••••",
                class: "mt-1.5 w-full rounded-[var(--radius-xl2)] border border-[color:var(--color-line)] bg-[color:var(--color-surface-2)] px-4 py-3 text-[color:var(--color-ink)] outline-none transition focus:border-[color:var(--color-electric)]" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <label class="flex cursor-pointer items-center gap-2 text-sm text-[color:var(--color-muted)]">
            <%= f.check_box :remember_me, class: "h-4 w-4 accent-[color:var(--color-accent)]" %>
            Remember me
          </label>
        <% end %>

        <%= f.submit t("nav.sign_in"), class: "btn btn-primary w-full cursor-pointer text-base" %>
      <% end %>

      <% if devise_mapping.registerable? %>
        <p class="mt-6 text-center text-sm text-[color:var(--color-muted)]">
          New here?
          <%= link_to "Create an account", new_registration_path(resource_name), class: "font-semibold text-[color:var(--color-electric)] hover:underline" %>
        </p>
      <% end %>

      <%# Demo credentials — convenience for reviewers %>
      <div class="mt-8 border border-dashed border-[color:var(--color-line)] p-4">
        <p class="font-mono2 text-[10px] uppercase tracking-widest text-[color:var(--color-faint)]">Demo access</p>
        <div class="mt-2 grid gap-1 font-mono2 text-xs text-[color:var(--color-muted)]">
          <span>admin@apexkarting.example · password</span>
          <span>driver@apexkarting.example · password</span>
        </div>
      </div>
    </div>
  </div>
</section>
