<footer class="mt-24 border-t border-[color:var(--color-line)] bg-[color:var(--color-surface)]/60">
  <div class="mx-auto grid max-w-7xl gap-10 px-5 py-14 md:grid-cols-4">
    <div class="md:col-span-2">
      <div class="flex items-center gap-2 font-display text-xl font-black">
        <span class="gradient-text"><%= current_venue.name.upcase %></span>
      </div>
      <p class="mt-3 max-w-sm text-sm text-[color:var(--color-muted)]"><%= t("meta.description") %></p>
      <div class="mt-5 flex gap-3">
        <% { facebook: current_venue.facebook, instagram: current_venue.instagram, youtube: current_venue.youtube, tiktok: current_venue.tiktok }.each do |name, url| %>
          <% if url.present? %><%= link_to name.to_s.capitalize, url, class: "chip", target: "_blank", rel: "noopener" %><% end %>
        <% end %>
      </div>
    </div>

    <div>
      <h4 class="font-display text-sm uppercase tracking-widest text-[color:var(--color-muted)]"><%= t("footer.explore") %></h4>
      <ul class="mt-4 space-y-2 text-sm">
        <li><%= link_to t("nav.karts"), karts_path, class: "text-[color:var(--color-muted)] hover:text-white" %></li>
        <li><%= link_to t("nav.pricing"), pricing_index_path, class: "text-[color:var(--color-muted)] hover:text-white" %></li>
        <li><%= link_to t("nav.competitions"), competitions_path, class: "text-[color:var(--color-muted)] hover:text-white" %></li>
        <li><%= link_to t("nav.records"), records_path, class: "text-[color:var(--color-muted)] hover:text-white" %></li>
      </ul>
    </div>

    <div>
      <h4 class="font-display text-sm uppercase tracking-widest text-[color:var(--color-muted)]"><%= t("footer.visit") %></h4>
      <ul class="mt-4 space-y-2 text-sm text-[color:var(--color-muted)]">
        <li><%= current_venue.address.presence || t("footer.address_tbd") %></li>
        <li><%= current_venue.phone %></li>
        <li><%= current_venue.email %></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-[color:var(--color-line)] px-5 py-5 text-center text-xs text-[color:var(--color-faint)]">
    © <%= Date.current.year %> <%= current_venue.name %>. <%= t("footer.rights") %>
  </div>
</footer>
