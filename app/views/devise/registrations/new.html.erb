<% content_for :title, "#{t('devise.registrations.new.sign_up', default: 'Create account')} — #{current_venue.name}" %>

<section class="mx-auto grid min-h-[calc(100dvh-4rem)] max-w-7xl lg:grid-cols-2">
  <%# ── Left: image panel (desktop) ── %>
  <div class="relative hidden overflow-hidden border-e border-[color:var(--color-line)] lg:block">
    <%= image_tag "karts/sport.jpg", alt: "", class: "absolute inset-0 h-full w-full object-cover" %>
    <div class="absolute inset-0" style="background:linear-gradient(120deg, var(--color-night) 8%, transparent 70%), linear-gradient(0deg, var(--color-night) 4%, transparent 45%)"></div>
    <div class="hazard hazard-red absolute inset-x-0 top-0"></div>

    <div class="relative flex h-full flex-col justify-between p-10">
      <span class="chip w-fit"><span class="live-dot"></span> <%= current_venue.city %> · <%= current_venue.country %></span>
      <div>
        <p class="font-mono2 text-xs uppercase tracking-[0.3em] text-[color:var(--color-electric)]">Join the grid</p>
        <h2 class="skew-speed mt-3 text-6xl text-[color:var(--color-ink)]">Race with us</h2>
        <p class="mt-4 max-w-sm text-sm text-[color:var(--color-muted)]">Create your driver account — book sessions, register for competitions and track your lap records.</p>
      </div>
    </div>
  </div>

  <%# ── Right: form ── %>
  <div class="flex items-center justify-center px-5 py-12 sm:px-10">
    <div class="w-full max-w-sm animate-rise">
      <span class="font-mono2 text-xs uppercase tracking-[0.3em] text-[color:var(--color-muted)]">// New driver</span>
      <h1 class="mt-2 text-5xl">Create account</h1>
      <div class="hazard mt-4 w-24"></div>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "mt-8 space-y-5" }) do |f| %>
        <% if resource.errors.any? %>
          <div class="rounded-[var(--radius-xl2)] border border-[color:var(--color-accent)] bg-[color:var(--color-accent)]/10 px-4 py-3 text-sm text-[color:var(--color-ink)]">
            <%= resource.errors.full_messages.to_sentence %>
          </div>
        <% end %>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <%= f.label :first_name, "First name", class: "font-mono2 text-[11px] uppercase tracking-widest text-[color:var(--color-muted)]" %>
            <%= f.text_field :first_name, autocomplete: "given-name",
                  class: "mt-1.5 w-full rounded-[var(--radius-xl2)] border border-[color:var(--color-line)] bg-[color:var(--color-surface-2)] px-4 py-3 text-[color:var(--color-ink)] outline-none transition focus:border-[color:var(--color-electric)]" %>
          </div>
          <div>
            <%= f.label :last_name, "Last name", class: "font-mono2 text-[11px] uppercase tracking-widest text-[color:var(--color-muted)]" %>
            <%= f.text_field :last_name, autocomplete: "family-name",
                  class: "mt-1.5 w-full rounded-[var(--radius-xl2)] border border-[color:var(--color-line)] bg-[color:var(--color-surface-2)] px-4 py-3 text-[color:var(--color-ink)] outline-none transition focus:border-[color:var(--color-electric)]" %>
          </div>
        </div>

        <div>
          <%= f.label :birthday, t("contact.birthday"), class: "font-mono2 text-[11px] uppercase tracking-widest text-[color:var(--color-muted)]" %>
          <%= f.date_field :birthday, autocomplete: "bday", placeholder: "YYYY-MM-DD",
                class: "mt-1.5 w-full rounded-[var(--radius-xl2)] border border-[color:var(--color-line)] bg-[color:var(--color-surface-2)] px-4 py-3 text-[color:var(--color-ink)] outline-none transition focus:border-[color:var(--color-electric)]" %>
        </div>

        <div>
          <%= f.label :email, t("contact.email"), class: "font-mono2 text-[11px] uppercase tracking-widest text-[color:var(--color-muted)]" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "you@example.com",
                class: "mt-1.5 w-full rounded-[var(--radius-xl2)] border border-[color:var(--color-line)] bg-[color:var(--color-surface-2)] px-4 py-3 text-[color:var(--color-ink)] outline-none transition focus:border-[color:var(--color-electric)]" %>
        </div>

        <div>
          <%= f.label :password, "Password", class: "font-mono2 text-[11px] uppercase tracking-widest text-[color:var(--color-muted)]" %>
          <%= f.password_field :password, autocomplete: "new-password", placeholder: "••••••••",
                class: "mt-1.5 w-full rounded-[var(--radius-xl2)] border border-[color:var(--color-line)] bg-[color:var(--color-surface-2)] px-4 py-3 text-[color:var(--color-ink)] outline-none transition focus:border-[color:var(--color-electric)]" %>
          <% if @minimum_password_length %>
            <p class="mt-1 font-mono2 text-[10px] uppercase tracking-widest text-[color:var(--color-faint)]"><%= @minimum_password_length %>+ characters</p>
          <% end %>
        </div>

        <div>
          <%= f.label :password_confirmation, "Confirm password", class: "font-mono2 text-[11px] uppercase tracking-widest text-[color:var(--color-muted)]" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "••••••••",
                class: "mt-1.5 w-full rounded-[var(--radius-xl2)] border border-[color:var(--color-line)] bg-[color:var(--color-surface-2)] px-4 py-3 text-[color:var(--color-ink)] outline-none transition focus:border-[color:var(--color-electric)]" %>
        </div>

        <%= f.submit "Create account", class: "btn btn-primary w-full cursor-pointer text-base" %>
      <% end %>

      <p class="mt-6 text-center text-sm text-[color:var(--color-muted)]">
        Already have an account?
        <%= link_to t("nav.sign_in"), new_session_path(resource_name), class: "font-semibold text-[color:var(--color-electric)] hover:underline" %>
      </p>
    </div>
  </div>
</section>
