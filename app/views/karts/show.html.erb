<% content_for :title, "#{@kart.name} — #{current_venue.name}" %>
<section class="mx-auto max-w-6xl px-5 py-10">
  <%= link_to karts_path, class: "text-sm text-[color:var(--color-muted)] hover:text-white" do %>← <%= t("karts.title") %><% end %>
  <div class="mt-5 grid gap-8 lg:grid-cols-2">
    <div class="card overflow-hidden">
      <div class="aspect-[4/3] bg-[color:var(--color-surface-2)]">
        <% if @kart.photo.attached? %>
          <%= image_tag @kart.photo, class: "h-full w-full object-cover" %>
        <% else %>
          <div class="grid h-full place-items-center text-[color:var(--color-faint)]"><%= icon(:gauge, css: "h-16 w-16") %></div>
        <% end %>
      </div>
    </div>

    <div>
      <span class="chip"><%= @kart.category.to_s.titleize %></span>
      <h1 class="mt-3 font-display text-4xl font-black"><%= @kart.name %></h1>
      <p class="mt-3 text-[color:var(--color-muted)]"><%= @kart.description %></p>

      <h2 class="mt-8 font-display text-lg font-bold"><%= t("karts.specs") %></h2>
      <div class="mt-3 grid grid-cols-2 gap-3">
        <% [[t("karts.top_speed"), "#{@kart.top_speed_kmh} km/h"], [t("karts.power"), "#{@kart.power_hp} hp"], [t("karts.weight"), "#{@kart.weight_kg} kg"], [t("karts.engine"), @kart.engine], [t("karts.min_age"), @kart.min_age]].each do |label, value| %>
          <div class="card p-4"><div class="text-xs uppercase tracking-wider text-[color:var(--color-faint)]"><%= label %></div><div class="mt-1 font-display text-lg"><%= value.presence || "—" %></div></div>
        <% end %>
      </div>

      <% if @sessions.any? %>
        <h2 class="mt-8 font-display text-lg font-bold"><%= t("pricing.title") %></h2>
        <div class="mt-3 space-y-2">
          <% @sessions.each do |s| %>
            <div class="card flex items-center justify-between p-4">
              <div><div class="font-medium"><%= s.name %></div><div class="text-xs text-[color:var(--color-faint)]"><%= s.duration_minutes %> <%= t("pricing.minutes") %></div></div>
              <div class="font-display text-lg gradient-text"><%= s.price.format %></div>
            </div>
          <% end %>
        </div>
      <% end %>

      <%= link_to t("karts.book_this"), new_account_booking_path(kart_type_id: @kart.id), class: "btn btn-primary mt-8 w-full" %>
    </div>
  </div>

  <% if @related.any? %>
    <h2 class="mt-16 font-display text-2xl font-bold"><%= t("home.featured_karts") %></h2>
    <div class="mt-5 grid grid-cols-2 gap-4 md:grid-cols-3"><% @related.each { |k| %><%= render "karts/card", kart: k %><% } %></div>
  <% end %>
</section>
