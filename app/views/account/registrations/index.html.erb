<h1 class="font-display text-3xl font-black"><%= t("account.my_registrations") %></h1>
<div class="mt-6 space-y-3">
  <% @registrations.each do |r| %>
    <div class="card flex items-center justify-between p-4">
      <div>
        <div class="font-medium"><%= r.registerable.try(:name) %></div>
        <div class="text-xs text-[color:var(--color-faint)]"><%= r.reference %> · <%= r.registerable_type %></div>
      </div>
      <span class="chip"><%= r.status %></span>
    </div>
  <% end %>
  <% if @registrations.empty? %><p class="text-[color:var(--color-muted)]"><%= t("account.none") %></p><% end %>
</div>
