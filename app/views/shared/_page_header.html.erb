<header class="relative overflow-hidden border-b border-[color:var(--color-line)]">
  <div class="absolute inset-0 -z-10" style="background:radial-gradient(700px 320px at 30% -20%, rgba(255,45,45,0.14), transparent 60%)"></div>
  <div class="mx-auto max-w-7xl px-5 py-12 md:py-16">
    <h1 class="animate-rise font-display text-4xl font-black md:text-6xl"><%= title %></h1>
    <% if local_assigns[:subtitle].present? %>
      <p class="animate-rise mt-3 max-w-2xl text-[color:var(--color-muted)] md:text-lg"><%= subtitle %></p>
    <% end %>
  </div>
</header>
