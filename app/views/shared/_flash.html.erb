<% flash.each do |type, message| %>
  <% next if message.blank? %>
  <% color = type.to_s == "alert" ? "var(--color-accent)" : "var(--color-electric)" %>
  <div class="glass mx-auto mt-4 flex max-w-3xl items-center gap-3 px-5 py-3 text-sm animate-rise" style="border-color:<%= color %>33">
    <span class="h-2 w-2 rounded-full" style="background:<%= color %>"></span>
    <%= message %>
  </div>
<% end %>
