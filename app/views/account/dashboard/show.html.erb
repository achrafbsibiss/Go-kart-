<h1 class="font-display text-3xl font-black"><%= t("account.welcome", name: current_user.full_name) %></h1>

<div class="mt-6 grid grid-cols-2 gap-3 md:grid-cols-4">
  <% [[@bookings.size, t("account.my_bookings")], [@registrations.size, t("account.my_registrations")], [@driver&.total_races || 0, t("drivers.races")], [@driver&.best_lap_label || "—", t("drivers.best_lap")]].each do |v, l| %>
    <div class="glass p-5"><div class="font-display text-2xl font-bold gradient-text"><%= v %></div><div class="mt-1 text-xs text-[color:var(--color-muted)]"><%= l %></div></div>
  <% end %>
</div>

<div class="mt-8 flex items-center justify-between">
  <h2 class="font-display text-xl font-bold"><%= t("account.upcoming") %></h2>
  <%= link_to t("account.new_booking"), new_account_booking_path, class: "btn btn-primary !px-4 !py-2 text-sm" %>
</div>

<div class="mt-4 space-y-3">
  <% if @bookings.any? %>
    <% @bookings.each do |b| %>
      <%= link_to account_booking_path(b), class: "card flex items-center justify-between p-4 hover:border-white/20" do %>
        <div>
          <div class="font-medium"><%= b.session_price&.name || t("nav.book") %></div>
          <div class="text-xs text-[color:var(--color-faint)]"><%= l(b.starts_at, format: :long) if b.starts_at %></div>
        </div>
        <span class="chip"><%= b.status %></span>
      <% end %>
    <% end %>
  <% else %>
    <div class="card grid place-items-center p-10 text-center text-[color:var(--color-muted)]">
      <%= icon(:ticket, css: "h-10 w-10 opacity-40") %><p class="mt-3"><%= t("account.none") %></p>
    </div>
  <% end %>
</div>
