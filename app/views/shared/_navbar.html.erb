<header class="sticky top-0 z-50 bg-[color:var(--color-night)]/95 backdrop-blur-[2px]">
  <nav class="flex items-stretch justify-between gap-2 border-b border-[color:var(--color-line)] pe-2 sm:pe-3">
    <%# Logo jammed hard to the left edge, square block %>
    <%= link_to root_path, class: "group flex min-w-0 items-center gap-2 border-e border-[color:var(--color-line)] pe-3 ps-3 sm:gap-3 sm:pe-5 sm:ps-4" do %>
      <span class="grid h-8 w-8 shrink-0 place-items-center bg-[color:var(--color-accent)]"><%= icon(:flag, css: "h-5 w-5 text-[color:var(--color-ink)]") %></span>
      <span class="font-display truncate text-base tracking-tight sm:text-xl"><%= current_venue.name.upcase %></span>
    <% end %>

    <div class="hidden items-center lg:flex">
      <% [[t("nav.karts"), karts_path], [t("nav.pricing"), pricing_index_path], [t("nav.memberships"), memberships_path], [t("nav.competitions"), competitions_path], [t("nav.live"), live_path], [t("nav.records"), records_path], [t("nav.gallery"), gallery_index_path], [t("nav.contact"), contact_path]].each do |label, path| %>
        <%= link_to label, path, class: "font-mono2 px-3 py-5 text-xs font-bold uppercase tracking-wider transition #{nav_active?(path) ? 'text-[color:var(--color-electric)]' : 'text-[color:var(--color-muted)] hover:text-[color:var(--color-ink)]'}" %>
      <% end %>
    </div>

    <div class="flex shrink-0 items-center gap-2 py-2 sm:gap-3">
      <%= link_to live_path, class: "font-mono2 hidden items-center gap-1.5 text-xs font-bold uppercase tracking-wider text-[color:var(--color-electric)] sm:flex" do %>
        <span class="live-dot"></span> <%= t("nav.live") %>
      <% end %>

      <details class="relative">
        <summary class="chip cursor-pointer list-none"><%= I18n.locale.to_s.upcase %></summary>
        <div class="card absolute end-0 mt-2 w-36 overflow-hidden p-1">
          <% locale_switcher_options.each do |loc, label| %>
            <%= link_to label, url_for(locale: loc), class: "block px-3 py-2 text-sm hover:bg-white/5 #{'text-[color:var(--color-electric)]' if I18n.locale == loc}" %>
          <% end %>
        </div>
      </details>

      <% if user_signed_in? %>
        <%= link_to account_dashboard_path, class: "btn btn-ghost !px-3 !py-2" do %><%= icon(:user, css: "h-5 w-5") %><% end %>
        <% if current_user.staff_or_admin? %><%= link_to t("nav.admin"), admin_dashboard_path, class: "font-mono2 hidden text-xs uppercase tracking-wider text-[color:var(--color-muted)] hover:text-white md:block" %><% end %>
      <% else %>
        <%= link_to t("nav.sign_in"), new_user_session_path, class: "font-mono2 hidden text-xs uppercase tracking-wider text-[color:var(--color-muted)] hover:text-white sm:block" %>
      <% end %>

      <%= link_to t("nav.book"), new_account_booking_path, class: "btn btn-primary !px-4 !py-2 text-xs" %>
    </div>
  </nav>
</header>
