<div class="card overflow-hidden">
  <% (0..6).each do |dow| %>
    <% oh = opening_hours.find { |h| h.day_of_week == dow } %>
    <div class="flex items-center justify-between border-b border-[color:var(--color-line)]/50 px-4 py-3 text-sm <%= 'bg-white/[0.03]' if dow == Time.current.wday %>">
      <span class="capitalize"><%= I18n.t("date.day_names")[dow] %></span>
      <% if oh.nil? || oh.closed? %>
        <span class="text-[color:var(--color-faint)]"><%= t("contact.closed") %></span>
      <% else %>
        <span class="font-mono"><%= oh.opens_at&.strftime("%H:%M") %> – <%= oh.closes_at&.strftime("%H:%M") %></span>
      <% end %>
    </div>
  <% end %>
</div>
