<% content_for :title, "#{t('actions.edit')} #{model_class.model_name.human}" %>
<%= link_to "← #{model_class.model_name.human(count: 2)}", polymorphic_path([:admin, model_class]), class: "text-sm text-[color:var(--color-muted)] hover:text-white" %>
<div class="mt-3 flex items-center justify-between">
  <h1 class="font-display text-3xl font-black"><%= t("actions.edit") %> <%= model_class.model_name.human %></h1>
  <%= button_to t("actions.delete"), polymorphic_path([:admin, @record]), method: :delete, class: "btn btn-ghost !px-4 !py-2 text-sm", data: { turbo_confirm: "?" } rescue nil %>
</div>
<div class="mt-6 max-w-2xl"><%= render "admin/resources/form", record: @record %></div>
