<%# ===== HERO ===== %>
<section class="relative overflow-hidden">
  <div class="absolute inset-0 -z-10">
    <div class="absolute inset-0" style="background:radial-gradient(900px 500px at 70% 0%, rgba(255,45,45,0.18), transparent 60%)"></div>
    <div class="absolute inset-0 opacity-[0.04]" style="background-image:linear-gradient(var(--color-ink) 1px,transparent 1px),linear-gradient(90deg,var(--color-ink) 1px,transparent 1px);background-size:48px 48px"></div>
  </div>

  <div class="mx-auto flex max-w-7xl flex-col items-center px-5 pb-16 pt-14 text-center md:pt-24">
    <span class="chip animate-rise"><span class="live-dot"></span><%= t("home.hero_eyebrow") %></span>
    <h1 class="animate-rise mt-6 font-display text-6xl font-black leading-[0.95] sm:text-7xl md:text-8xl">
      <%= t("home.hero_title_1") %><br><span class="gradient-text"><%= t("home.hero_title_2") %></span>
    </h1>
    <p class="animate-rise mt-6 max-w-xl text-base text-[color:var(--color-muted)] md:text-lg"><%= t("home.hero_sub") %></p>
    <div class="animate-rise mt-8 flex flex-wrap items-center justify-center gap-3">
      <%= link_to t("home.book_now"), new_account_booking_path, class: "btn btn-primary text-base" %>
      <%= link_to live_path, class: "btn btn-ghost text-base" do %><span class="live-dot"></span> <%= t("home.watch_live") %><% end %>
    </div>

    <%# Stats bar %>
    <div class="glass mt-14 grid w-full max-w-3xl grid-cols-2 gap-px overflow-hidden md:grid-cols-4">
      <% [[(@featured_karts.map(&:top_speed_kmh).compact.max || 80).to_s + " km/h", t("home.stat_top_speed")],
          [(@track&.length_m || 1100).to_s + " m", t("home.stat_track")],
          [(@track&.corners || 14).to_s, t("home.stat_corners")],
          [current_venue.open_now? ? t("home.open_now") : t("home.closed_now"), t("nav.home")]].each do |value, label| %>
        <div class="p-5">
          <div class="font-display text-2xl font-bold gradient-text"><%= value %></div>
          <div class="mt-1 text-xs uppercase tracking-widest text-[color:var(--color-muted)]"><%= label %></div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ===== LIVE NOW ===== %>
<section class="mx-auto max-w-7xl px-5 py-12">
  <div class="mb-6 flex items-center justify-between">
    <h2 class="flex items-center gap-3 font-display text-2xl font-bold"><span class="live-dot"></span><%= t("home.live_now") %></h2>
    <%= link_to t("home.view_all"), live_path, class: "text-sm text-[color:var(--color-muted)] hover:text-white" %>
  </div>
  <% if @live_races.any? %>
    <div class="grid gap-4 md:grid-cols-3">
      <% @live_races.each do |race| %><%= render "races/live_card", race: race %><% end %>
    </div>
  <% else %>
    <div class="card grid place-items-center p-12 text-center text-[color:var(--color-muted)]">
      <%= icon(:flag, css: "h-10 w-10 opacity-40") %>
      <p class="mt-3"><%= t("home.no_live") %></p>
    </div>
  <% end %>
</section>

<%# ===== FEATURED KARTS ===== %>
<section class="mx-auto max-w-7xl px-5 py-12">
  <div class="mb-6 flex items-center justify-between">
    <h2 class="font-display text-2xl font-bold"><%= t("home.featured_karts") %></h2>
    <%= link_to t("home.view_all"), karts_path, class: "text-sm text-[color:var(--color-muted)] hover:text-white" %>
  </div>
  <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
    <% @featured_karts.each do |kart| %><%= render "karts/card", kart: kart %><% end %>
  </div>
</section>

<%# ===== UPCOMING ===== %>
<% if @upcoming_competitions.any? || @upcoming_events.any? %>
  <section class="mx-auto max-w-7xl px-5 py-12">
    <h2 class="mb-6 font-display text-2xl font-bold"><%= t("home.upcoming_events") %></h2>
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      <% @upcoming_competitions.each do |c| %>
        <%= link_to competition_path(c), class: "card p-6 transition hover:-translate-y-1" do %>
          <span class="chip"><%= t("competitions.format.#{c.format}", default: c.format) %></span>
          <h3 class="mt-3 font-display text-lg font-bold"><%= c.name %></h3>
          <p class="mt-1 text-sm text-[color:var(--color-muted)]"><%= l(c.starts_at, format: :long) if c.starts_at %></p>
        <% end %>
      <% end %>
      <% @upcoming_events.each do |e| %>
        <%= link_to event_path(e), class: "card p-6 transition hover:-translate-y-1" do %>
          <span class="chip"><%= t("events.title") %></span>
          <h3 class="mt-3 font-display text-lg font-bold"><%= e.name %></h3>
          <p class="mt-1 text-sm text-[color:var(--color-muted)]"><%= l(e.starts_at, format: :long) if e.starts_at %></p>
        <% end %>
      <% end %>
    </div>
  </section>
<% end %>

<%# ===== CTA ===== %>
<section class="mx-auto max-w-7xl px-5 py-16">
  <div class="glass relative overflow-hidden p-10 text-center md:p-16">
    <div class="absolute inset-0 -z-10" style="background:radial-gradient(600px 300px at 50% 120%, rgba(21,240,200,0.18), transparent)"></div>
    <h2 class="font-display text-3xl font-black md:text-5xl"><%= t("home.book_now") %></h2>
    <p class="mx-auto mt-4 max-w-lg text-[color:var(--color-muted)]"><%= t("home.hero_sub") %></p>
    <%= link_to t("home.book_now"), new_account_booking_path, class: "btn btn-primary mt-8 text-base" %>
  </div>
</section>
