<% content_for :title, "#{t('events.title')} — #{current_venue.name}" %>
<%= render "shared/page_header", title: t("events.title"), subtitle: t("events.subtitle") %>
<section class="mx-auto max-w-6xl px-5 py-10">
  <% if @upcoming.any? %>
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      <% @upcoming.each do |e| %>
        <%= link_to event_path(e), class: "card overflow-hidden hover:border-white/20" do %>
          <div class="relative h-40 bg-[color:var(--color-surface-2)]">
            <% if e.banner.attached? %><%= image_tag e.banner, class: "h-full w-full object-cover" %><% end %>
            <span class="chip absolute left-4 top-4 bg-black/40"><%= t("events.title") %></span>
          </div>
          <div class="p-5">
            <h3 class="font-display text-lg font-bold"><%= e.name %></h3>
            <p class="mt-1 text-sm text-[color:var(--color-muted)]"><%= l(e.starts_at, format: :long) if e.starts_at %></p>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <p class="text-[color:var(--color-muted)]"><%= t("account.none") %></p>
  <% end %>
</section>
