<% content_for :title, t("admin.dashboard") %>
<h1 class="font-display text-3xl font-black"><%= t("admin.overview") %></h1>

<div class="mt-6 grid grid-cols-2 gap-3 md:grid-cols-4">
  <% [[@counts[:drivers], t("drivers.title")], [@counts[:bookings], t("account.my_bookings")], [@counts[:competitions], t("nav.competitions")], [money(@counts[:revenue_cents]), "Revenue"]].each do |v, l| %>
    <div class="glass p-5"><div class="font-display text-2xl font-bold gradient-text"><%= v %></div><div class="mt-1 text-xs text-[color:var(--color-muted)]"><%= l %></div></div>
  <% end %>
</div>

<div class="mt-8 grid gap-6 lg:grid-cols-2">
  <div>
    <h2 class="flex items-center gap-2 font-display text-xl font-bold"><span class="live-dot"></span><%= t("admin.live_races") %></h2>
    <div class="mt-3 space-y-2">
      <% @live_races.each do |race| %>
        <div class="card flex items-center justify-between p-4">
          <%= link_to race.name.presence || "Race ##{race.id}", admin_race_path(race), class: "font-medium hover:underline" %>
          <%= button_to t("admin.finish"), finish_admin_race_path(race), class: "btn btn-ghost !px-3 !py-1.5 text-xs" %>
        </div>
      <% end %>
      <% if @live_races.empty? %><p class="text-sm text-[color:var(--color-faint)]"><%= t("races.no_live") %></p><% end %>
    </div>

    <h2 class="mt-6 font-display text-xl font-bold"><%= t("races.upcoming") %></h2>
    <div class="mt-3 space-y-2">
      <% @scheduled_races.each do |race| %>
        <div class="card flex items-center justify-between p-4">
          <%= link_to race.name.presence || "Race ##{race.id}", admin_race_path(race), class: "font-medium hover:underline" %>
          <%= button_to t("admin.start"), start_admin_race_path(race), class: "btn btn-primary !px-3 !py-1.5 text-xs" %>
        </div>
      <% end %>
    </div>
  </div>

  <div>
    <h2 class="font-display text-xl font-bold"><%= t("admin.today_bookings") %></h2>
    <div class="card mt-3 overflow-hidden">
      <% @today_bookings.each do |b| %>
        <div class="flex items-center justify-between border-b border-[color:var(--color-line)]/50 px-4 py-3 text-sm">
          <span><%= b.user.full_name %></span>
          <span class="text-[color:var(--color-faint)]"><%= l(b.starts_at, format: :short) if b.starts_at %></span>
        </div>
      <% end %>
      <% if @today_bookings.empty? %><p class="px-4 py-6 text-center text-sm text-[color:var(--color-faint)]"><%= t("account.none") %></p><% end %>
    </div>

    <h2 class="mt-6 font-display text-xl font-bold"><%= t("admin.registrations") %></h2>
    <div class="card mt-3 overflow-hidden">
      <% @recent_registrations.each do |r| %>
        <div class="flex items-center justify-between border-b border-[color:var(--color-line)]/50 px-4 py-3 text-sm">
          <span><%= r.user.full_name %> → <%= r.registerable.try(:name) %></span>
          <span class="chip"><%= r.status %></span>
        </div>
      <% end %>
    </div>
  </div>
</div>
