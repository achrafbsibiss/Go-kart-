<section class="mx-auto grid min-h-[60vh] max-w-md place-items-center px-5 text-center">
  <div>
    <span class="mx-auto grid h-16 w-16 place-items-center rounded-2xl bg-white/5"><%= icon(:bolt, css: "h-8 w-8 text-[color:var(--color-accent)]") %></span>
    <h1 class="mt-6 font-display text-3xl font-black">Offline</h1>
    <p class="mt-3 text-[color:var(--color-muted)]">You're offline. Reconnect to see live timing and book sessions.</p>
    <%= link_to "Retry", root_path, class: "btn btn-primary mt-6", data: { turbo: false } %>
  </div>
</section>
