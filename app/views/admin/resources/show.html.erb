<% content_for :title, model_class.model_name.human %>
<%= link_to "← #{model_class.model_name.human(count: 2)}", polymorphic_path([:admin, model_class]), class: "text-sm text-[color:var(--color-muted)] hover:text-white" %>
<h1 class="mt-3 font-display text-3xl font-black"><%= @record.try(:name) || @record.try(:display_name) || "##{@record.id}" %></h1>
<div class="card mt-6 max-w-2xl p-6">
  <dl class="grid grid-cols-2 gap-4 text-sm">
    <% resource_columns.each do |col| %>
      <div><dt class="text-[color:var(--color-faint)]"><%= col.humanize %></dt><dd class="mt-1 font-medium"><%= @record.public_send(col) %></dd></div>
    <% end %>
  </dl>
</div>
