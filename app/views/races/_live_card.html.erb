<%= link_to race_path(race), class: "card block overflow-hidden p-5 transition hover:-translate-y-1 hover:border-white/20" do %>
  <div class="flex items-center justify-between">
    <span class="chip <%= 'border-[color:var(--color-accent)]' if race.live? %>">
      <% if race.live? %><span class="live-dot"></span><% end %>
      <%= t("races.status.#{race.status}") %>
    </span>
    <span class="text-xs text-[color:var(--color-faint)]"><%= race.track&.name %></span>
  </div>
  <h3 class="mt-3 font-display text-lg font-bold"><%= race.name.presence || "Race ##{race.id}" %></h3>
  <div class="mt-4 space-y-1.5">
    <% race.leaderboard.first(3).each_with_index do |entry, i| %>
      <div class="flex items-center gap-3 text-sm">
        <span class="grid h-6 w-6 place-items-center rounded-lg bg-white/5 font-display text-xs"><%= i + 1 %></span>
        <span class="flex-1 truncate"><%= entry.driver_name %></span>
        <span class="font-mono text-xs text-[color:var(--color-electric)]"><%= entry.best_lap_label %></span>
      </div>
    <% end %>
    <% if race.race_entries.empty? %><p class="text-sm text-[color:var(--color-faint)]">—</p><% end %>
  </div>
<% end %>
