<h1 class="font-display text-3xl font-black"><%= t("account.my_subscriptions") %></h1>

<% if @subscriptions.any? %>
  <div class="mt-6 space-y-3">
    <% @subscriptions.each do |s| %>
      <div class="card flex items-center justify-between p-5">
        <div>
          <div class="font-display font-bold"><%= s.membership_plan.name %></div>
          <div class="text-xs text-[color:var(--color-faint)]"><%= s.membership_plan.price.format %> <%= t("memberships.period.#{s.membership_plan.period}") %></div>
        </div>
        <span class="chip"><%= s.status %></span>
      </div>
    <% end %>
  </div>
<% end %>

<h2 class="mt-10 font-display text-xl font-bold"><%= t("memberships.title") %></h2>
<div class="mt-4 grid gap-4 md:grid-cols-3">
  <% @plans.each do |plan| %>
    <div class="card flex flex-col p-6 <%= 'ring-2 ring-[color:var(--color-accent)]' if plan.popular %>">
      <h3 class="font-display text-lg font-bold"><%= plan.name %></h3>
      <div class="mt-2 font-display text-2xl gradient-text"><%= plan.price.format %></div>
      <ul class="mt-3 flex-1 space-y-1 text-sm text-[color:var(--color-muted)]">
        <% plan.benefit_list.first(4).each { |b| %><li>✓ <%= b %></li><% } %>
      </ul>
      <%= button_to t("memberships.choose"), account_subscriptions_path(membership_plan_id: plan.id), class: "btn #{plan.popular ? 'btn-primary' : 'btn-ghost'} mt-5 w-full" %>
    </div>
  <% end %>
</div>
